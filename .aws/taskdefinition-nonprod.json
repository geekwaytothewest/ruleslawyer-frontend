{
  "containerDefinitions": [
    {
      "name": "ruleslawyer-frontend",
      "image": "784431842911.dkr.ecr.us-east-1.amazonaws.com/ruleslawyer-frontend:latest",
      "cpu": 0,
      "portMappings": [
        {
          "name": "ruleslawyer-frontend-3000-tcp",
          "containerPort": 3000,
          "hostPort": 3000,
          "protocol": "tcp",
          "appProtocol": "http"
        }
      ],
      "essential": true,
      "environment": [
        {
          "name": "NODE_ENV",
          "value": "production"
        },
        {
          "name": "PORT",
          "value": "3000"
        },
        {
          "name": "AUTH0_DOMAIN",
          "value": "geekway.auth0.com"
        },
        {
          "name": "AUTH0_CLIENT_ID",
          "value": "E6PJhdNknPqcVouOfHZ2F2JzTm7LU4z5"
        },
        {
          "name": "AUTH0_AUDIENCE",
          "value": "https://api.ruleslawyer.geekway.com"
        },
        {
          "name": "APP_BASE_URL",
          "value": "https://TODO-nonprod-domain/ruleslawyer"
        },
        {
          "name": "API_URL",
          "value": "https://TODO-nonprod-domain/api"
        },
        {
          "name": "NEXT_PUBLIC_API_URL",
          "value": "https://TODO-nonprod-domain/api"
        }
      ],
      "mountPoints": [],
      "volumesFrom": [],
      "secrets": [
        {
          "name": "AUTH0_SECRET",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:784431842911:secret:ruleslawyer-frontend-credentials-TODO:AUTH_SECRET::"
        },
        {
          "name": "AUTH0_CLIENT_SECRET",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:784431842911:secret:ruleslawyer-frontend-credentials-TODO:AUTH0_CLIENT_SECRET::"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-create-group": "true",
          "awslogs-group": "/ecs/",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "ecs"
        },
        "secretOptions": []
      }
    }
  ],
  "family": "ruleslawyer-frontend",
  "executionRoleArn": "arn:aws:iam::784431842911:role/ecsTaskExecutionRole",
  "networkMode": "awsvpc",
  "volumes": [],
  "placementConstraints": [],
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512",
  "runtimePlatform": {
    "cpuArchitecture": "X86_64",
    "operatingSystemFamily": "LINUX"
  },
  "tags": []
}
